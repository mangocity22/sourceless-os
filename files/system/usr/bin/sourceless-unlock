#!/usr/bin/bash
# /usr/bin/sourceless-unlock
# Utilitar securizat pentru activarea modului de suport tehnic

# 1. Ne asigurăm că tehnicianul a rulat scriptul cu sudo
if [ "$EUID" -ne 0 ]; then
    echo "[-] Error: This tool must be run with sudo privileges."
    echo "    Please run: sudo sourceless-unlock"
    exit 1
fi

# Definim parola master de suport
SUPPORT_KEY="SourcelessSupport2026!"

echo "=================================================="
echo "         Sourceless-OS // SUPPORT GATE            "
echo "=================================================="
echo "WARNING: Accessing this area breaks the security "
echo "seal and voids the system warranty immediately."
echo "=================================================="
echo ""

# Cerem cheia de securitate
read -s -p "Enter Support Authorization Key: " USER_KEY
echo ""

if [ "$USER_KEY" != "$SUPPORT_KEY" ]; then
    echo "[-] Invalid Authorization Key. Access Denied."
    logger -t "sourceless-security" -p user.err "FAILED SUPPORT UNLOCK ATTEMPT"
    exit 1
fi

echo "[+] Access Granted. Initiating Support Session..."
logger -t "sourceless-security" -p user.warn "SUPPORT SESSION ACTIVATED"

# Creăm fișierul capcană (fără sudo, pentru că scriptul e deja root!)
touch /etc/sourceless/.tamper_detected

# Lansăm shell-ul de root (folosim exec pentru a înlocui procesul curent)
exec /usr/bin/bash