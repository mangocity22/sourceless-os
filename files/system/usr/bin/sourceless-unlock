#!/usr/bin/bash
# /usr/bin/sourceless-unlock

# 1. Enforce root execution
if [ "$EUID" -ne 0 ]; then
    echo "[-] Error: This tool must be run with sudo privileges."
    echo "    Please run: sudo sourceless-unlock"
    exit 1
fi

# 2. Algoritmul de Rolling Password
CURRENT_DATE=$(date +%Y-%m-%d)
SECRET_SALT="SourcelessSecretSalt2026"

# Generăm cheia unică de 8 caractere pentru ziua de azi
GENERATED_KEY=$(echo -n "${CURRENT_DATE}-${SECRET_SALT}" | sha256sum | head -c 8)

echo "=================================================="
echo "         Sourceless-OS // SUPPORT GATE            "
echo "=================================================="
echo "WARNING: Accessing this area breaks the security "
echo "seal and voids the system warranty immediately."
echo "=================================================="
echo ""

# Cerem cheia de securitate tehnicianului
read -s -p "Enter Today's Support Authorization Key: " USER_KEY
echo ""

if [ "$USER_KEY" != "$GENERATED_KEY" ]; then
    echo "[-] Invalid Authorization Key. Access Denied."
    logger -t "sourceless-security" -p user.err "FAILED SUPPORT UNLOCK ATTEMPT - Wrong Dynamic Key"
    exit 1
fi

echo "[+] Access Granted. Initiating Support Session..."
logger -t "sourceless-security" -p user.warn "SUPPORT SESSION ACTIVATED VIA ROLLING KEY"

# Creăm fișierul capcană pentru Dashboard
touch /etc/sourceless/.tamper_detected

# Lansăm shell-ul de root
exec /usr/bin/bash